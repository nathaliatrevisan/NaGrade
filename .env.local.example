# Copie este arquivo para .env.local e preencha com seus valores reais
# NUNCA commite o .env.local no repositório

# Supabase — encontre em: https://app.supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# setlist.fm — cadastre-se em: https://api.setlist.fm/docs/1.0/ui/#!/default
# A chave é SERVER-SIDE ONLY — nunca use NEXT_PUBLIC_ aqui
SETLISTFM_API_KEY=sua_api_key_aqui
